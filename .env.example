# Anthropic-compatible API (e.g. MiniMax)
ANTHROPIC_BASE_URL=https://api.minimaxi.com/anthropic
ANTHROPIC_API_KEY=your_api_key_here

GRAPH_MODEL=MiniMax-M2.7
GRAPH_THINKING_BUDGET=0
GRAPH_CHUNK_BATCH_SIZE=10
GRAPH_MIN_LINES_PER_ROUND=0

# --- Embeddings (recommended: local sentence-transformers) ---
EMBEDDING_BACKEND=sentence_transformers
# Hugging Face model id or local snapshot path
ST_EMBED_MODEL=BAAI/bge-base-en-v1.5

# Optional: MiniMax REST embeddings
# EMBEDDING_BACKEND=minimax_rest
# MINIMAX_HTTP_BASE=https://api.minimaxi.com
# MINIMAX_EMBEDDING_MODEL=emb-o01

# Optional JSON map of relation synonym groups
# RELATION_SYNONYMS_PATH=relation_synonyms.json
